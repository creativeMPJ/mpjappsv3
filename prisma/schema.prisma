generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Region {
  id           String           @id @default(uuid()) @db.VarChar(36)
  name         String
  code         String           @unique
  createdAt    DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  cities       City[]
  followUpLogs FollowUpLog[]
  claims       PesantrenClaim[]
  profiles     Profile[]
  eventReports EventReport[]
  letters      Letter[]
  signatures   Signature[]
  templates    TemplatePosition[]

  @@map("regions")
}

model Event {
  id          String        @id @default(uuid()) @db.VarChar(36)
  name        String
  description String?       @db.Text
  date        DateTime
  location    String?
  status      String        @default("upcoming")
  createdAt   DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  report      EventReport[]

  @@map("events")
}

model EventReport {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  eventId            String   @map("event_id") @db.VarChar(36)
  regionId           String   @map("region_id") @db.VarChar(36)
  participationCount Int      @default(0) @map("participation_count")
  notes              String?  @db.Text
  photoUrl           String?  @map("photo_url")
  submittedAt        DateTime @default(now()) @map("submitted_at") @db.DateTime(0)

  event  Event  @relation(fields: [eventId], references: [id])
  region Region @relation(fields: [regionId], references: [id])

  @@map("event_reports")
}

model City {
  id        String    @id @default(uuid()) @db.VarChar(36)
  name      String
  regionId  String    @map("region_id") @db.VarChar(36)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  region    Region    @relation(fields: [regionId], references: [id])
  profiles  Profile[]

  @@map("cities")
}

model Profile {
  id              String        @id @db.VarChar(36)
  role            AppRole       @default(user)
  statusAccount   AccountStatus @default(pending) @map("status_account")
  statusPayment   PaymentStatus @default(unpaid) @map("status_payment")
  profileLevel    ProfileLevel  @default(basic) @map("profile_level")
  namaPesantren   String?       @map("nama_pesantren")
  namaPengasuh    String?       @map("nama_pengasuh")
  namaMedia       String?       @map("nama_media")
  alamatSingkat   String?       @map("alamat_singkat") @db.Text
  noWaPendaftar   String?       @map("no_wa_pendaftar")
  nip             String?
  cityId          String?       @map("city_id") @db.VarChar(36)
  regionId        String?       @map("region_id") @db.VarChar(36)
  logoUrl         String?       @map("logo_url")
  fotoPengasuhUrl String?       @map("foto_pengasuh_url")
  skPesantrenUrl  String?       @map("sk_pesantren_url")
  latitude        Decimal?      @db.Decimal(10, 8)
  longitude       Decimal?      @db.Decimal(11, 8)
  jumlahSantri    Int?          @map("jumlah_santri")
  tipePesantren   String?       @map("tipe_pesantren")
  programUnggulan Json?         @map("program_unggulan") // was String[] in PostgreSQL
  sejarah         String?       @db.Text
  visiMisi        String?       @map("visi_misi") @db.Text
  socialLinks     Json?         @map("social_links")

  isAlumni      Boolean @default(false) @map("is_alumni")
  niam          String? @unique

  alamatLengkap String? @map("alamat_lengkap") @db.Text
  kecamatan     String?
  desa          String?
  kodePos       String? @map("kode_pos")
  mapsLink      String? @map("maps_link")

  ketuaMedia    String? @map("ketua_media")
  tahunBerdiri  String? @map("tahun_berdiri")
  jumlahKru     Int?    @map("jumlah_kru")
  logoMediaUrl  String? @map("logo_media_path")
  fotoGedungUrl String? @map("foto_gedung_path")

  website   String?
  instagram String?
  facebook  String?
  youtube   String?
  tiktok    String?

  jenjangPendidikan Json? @map("jenjang_pendidikan")

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user     User             @relation(fields: [id], references: [id], onDelete: Cascade)
  crews    Crew[]
  payments Payment[]
  claims   PesantrenClaim[] @relation("claims_user")
  city     City?            @relation(fields: [cityId], references: [id])
  region   Region?          @relation(fields: [regionId], references: [id])

  @@map("profiles")
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(0)
  profile      Profile?
  lettersCreated Letter[] @relation("letters_created_by")
  lettersUpdated Letter[] @relation("letters_updated_by")
  signaturesCreated Signature[] @relation("signatures_created_by")
  signaturesUpdated Signature[] @relation("signatures_updated_by")
  templatePositionsCreated TemplatePosition[] @relation("template_positions_created_by")
  templatePositionsUpdated TemplatePosition[] @relation("template_positions_updated_by")

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  role      AppRole  @default(user)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)

  @@index([userId])
  @@map("user_roles")
}

model PesantrenClaim {
  id                 String           @id @default(uuid()) @db.VarChar(36)
  userId             String           @map("user_id") @db.VarChar(36)
  pesantrenName      String           @map("pesantren_name")
  jenisPengajuan     RegistrationType @default(pesantren_baru) @map("jenis_pengajuan")
  status             ClaimStatus      @default(pending)
  regionId           String?          @map("region_id") @db.VarChar(36)
  kecamatan          String?
  namaPengelola      String?          @map("nama_pengelola")
  emailPengelola     String?          @map("email_pengelola")
  dokumenBuktiUrl    String?          @map("dokumen_bukti_url")
  mpjIdNumber        String?          @map("mpj_id_number")
  notes              String?          @db.Text
  approvedBy         String?          @map("approved_by") @db.VarChar(36)
  approvedAt         DateTime?        @map("approved_at") @db.DateTime(0)
  regionalApprovedAt DateTime?        @map("regional_approved_at") @db.DateTime(0)
  claimedAt          DateTime         @default(now()) @map("claimed_at") @db.DateTime(0)
  createdAt          DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.DateTime(0)

  followUpLogs     FollowUpLog[]
  otpVerifications OtpVerification[]
  payments         Payment[]
  region           Region?           @relation(fields: [regionId], references: [id])
  user             Profile           @relation("claims_user", fields: [userId], references: [id])

  @@map("pesantren_claims")
}

model Payment {
  id               String                    @id @default(uuid()) @db.VarChar(36)
  userId           String                    @map("user_id") @db.VarChar(36)
  pesantrenClaimId String                    @map("pesantren_claim_id") @db.VarChar(36)
  pricingPackageId String?                   @map("pricing_package_id") @db.VarChar(36)
  baseAmount       Int                       @map("base_amount")
  uniqueCode       Int                       @map("unique_code")
  totalAmount      Int                       @map("total_amount")
  status           PaymentVerificationStatus @default(pending_payment)
  proofFileUrl     String?                   @map("proof_file_url")
  rejectionReason  String?                   @map("rejection_reason") @db.Text
  verifiedBy       String?                   @map("verified_by") @db.VarChar(36)
  verifiedAt       DateTime?                 @map("verified_at") @db.DateTime(0)
  createdAt        DateTime                  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt        DateTime                  @updatedAt @map("updated_at") @db.DateTime(0)

  claim          PesantrenClaim  @relation(fields: [pesantrenClaimId], references: [id])
  user           Profile         @relation(fields: [userId], references: [id])
  pricingPackage PricingPackage? @relation(fields: [pricingPackageId], references: [id])

  @@map("payments")
}

model PricingPackage {
  id          String          @id @default(uuid()) @db.VarChar(36)
  name        String
  category    PricingCategory
  hargaPaket  Int             @map("harga_paket")
  hargaDiskon Int?            @map("harga_diskon")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.DateTime(0)
  payments    Payment[]

  @@map("pricing_packages")
}

model JabatanCode {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String
  code        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  crews       Crew[]

  @@map("jabatan_codes")
}

model Crew {
  id            String       @id @default(uuid()) @db.VarChar(36)
  profileId     String       @map("profile_id") @db.VarChar(36)
  nama          String
  jabatan       String?
  jabatanCodeId String?      @map("jabatan_code_id") @db.VarChar(36)
  niam          String?
  skill         Json?        // was String[] in PostgreSQL
  xpLevel       Int          @default(0) @map("xp_level")
  createdAt     DateTime     @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.DateTime(0)
  jabatanCode   JabatanCode? @relation(fields: [jabatanCodeId], references: [id])
  profile       Profile      @relation(fields: [profileId], references: [id])

  @@map("crews")
}

model OtpVerification {
  id               String          @id @default(uuid()) @db.VarChar(36)
  userPhone        String          @map("user_phone")
  otpCode          String          @map("otp_code")
  pesantrenClaimId String?         @map("pesantren_claim_id") @db.VarChar(36)
  isVerified       Boolean         @default(false) @map("is_verified")
  attempts         Int             @default(0)
  expiresAt        DateTime        @map("expires_at") @db.DateTime(0)
  verifiedAt       DateTime?       @map("verified_at") @db.DateTime(0)
  createdAt        DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  claim            PesantrenClaim? @relation(fields: [pesantrenClaimId], references: [id])

  @@map("otp_verifications")
}

model FollowUpLog {
  id         String         @id @default(uuid()) @db.VarChar(36)
  adminId    String         @map("admin_id") @db.VarChar(36)
  claimId    String         @map("claim_id") @db.VarChar(36)
  regionId   String         @map("region_id") @db.VarChar(36)
  actionType String         @default("whatsapp_followup") @map("action_type")
  createdAt  DateTime       @default(now()) @map("created_at") @db.DateTime(0)
  claim      PesantrenClaim @relation(fields: [claimId], references: [id])
  region     Region         @relation(fields: [regionId], references: [id])

  @@map("follow_up_logs")
}

model PasswordResetRequest {
  id          String    @id @default(uuid()) @db.VarChar(36)
  email       String
  status      String    @default("pending")
  processedBy String?   @map("processed_by") @db.VarChar(36)
  processedAt DateTime? @map("processed_at") @db.DateTime(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)

  @@map("password_reset_requests")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.VarChar(36)
  key         String
  value       Json
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  @@map("system_settings")
}

model Letter {
  id              String             @id @default(uuid()) @db.VarChar(36)
  direction       LetterDirection
  scope           LetterScope
  regionId        String?            @map("region_id") @db.VarChar(36)
  letterNumber    String?            @map("letter_number")
  originNumber    String?            @map("origin_number")
  subject         String
  documentType    LetterDocumentType @map("document_type")
  senderName      String?            @map("sender_name")
  recipientName   String?            @map("recipient_name")
  signerName      String?            @map("signer_name")
  signerPosition  String?            @map("signer_position")
  letterDate      DateTime?          @map("letter_date") @db.DateTime(0)
  receivedAt      DateTime?          @map("received_at") @db.DateTime(0)
  status          LetterStatus       @default(draft)
  finalFileUrl    String?            @map("final_file_url")
  scanFileUrl     String?            @map("scan_file_url")
  validationQrUrl String?            @map("validation_qr_url")
  notes           String?            @db.Text
  createdById     String             @map("created_by_id") @db.VarChar(36)
  updatedById     String?            @map("updated_by_id") @db.VarChar(36)
  archivedAt      DateTime?          @map("archived_at") @db.DateTime(0)
  createdAt       DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.DateTime(0)

  region          Region?            @relation(fields: [regionId], references: [id])
  createdBy       User               @relation("letters_created_by", fields: [createdById], references: [id])
  updatedBy       User?              @relation("letters_updated_by", fields: [updatedById], references: [id])

  @@index([direction])
  @@index([scope])
  @@index([regionId])
  @@index([status])
  @@index([letterDate])
  @@index([createdAt])
  @@index([scope, regionId, direction, status])
  @@map("letters")
}

model Signature {
  id           String      @id @default(uuid()) @db.VarChar(36)
  scope        LetterScope
  regionId     String?     @map("region_id") @db.VarChar(36)
  leaderName   String      @map("leader_name")
  positionName String      @map("position_name")
  imageUrl     String      @map("image_url")
  isActive     Boolean     @default(true) @map("is_active")
  createdById  String      @map("created_by_id") @db.VarChar(36)
  updatedById  String?     @map("updated_by_id") @db.VarChar(36)
  createdAt    DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.DateTime(0)

  region       Region?     @relation(fields: [regionId], references: [id])
  createdBy    User        @relation("signatures_created_by", fields: [createdById], references: [id])
  updatedBy    User?       @relation("signatures_updated_by", fields: [updatedById], references: [id])

  @@index([scope])
  @@index([regionId])
  @@index([isActive])
  @@index([scope, regionId, positionName])
  @@map("signatures")
}

model TemplatePosition {
  id           String             @id @default(uuid()) @db.VarChar(36)
  scope        LetterScope
  regionId     String?            @map("region_id") @db.VarChar(36)
  documentType LetterDocumentType @map("document_type")
  numberX      Decimal            @map("number_x") @db.Decimal(10, 2)
  numberY      Decimal            @map("number_y") @db.Decimal(10, 2)
  signatureX   Decimal            @map("signature_x") @db.Decimal(10, 2)
  signatureY   Decimal            @map("signature_y") @db.Decimal(10, 2)
  qrX          Decimal            @map("qr_x") @db.Decimal(10, 2)
  qrY          Decimal            @map("qr_y") @db.Decimal(10, 2)
  fontSize     Int                @map("font_size")
  targetPage   Int                @default(1) @map("target_page")
  isActive     Boolean            @default(true) @map("is_active")
  createdById  String             @map("created_by_id") @db.VarChar(36)
  updatedById  String?            @map("updated_by_id") @db.VarChar(36)
  createdAt    DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.DateTime(0)

  region       Region?            @relation(fields: [regionId], references: [id])
  createdBy    User               @relation("template_positions_created_by", fields: [createdById], references: [id])
  updatedBy    User?              @relation("template_positions_updated_by", fields: [updatedById], references: [id])

  @@index([scope])
  @@index([regionId])
  @@index([documentType])
  @@index([isActive])
  @@index([scope, regionId, documentType])
  @@map("template_positions")
}

enum AccountStatus {
  pending
  active
  rejected
}

enum AppRole {
  user
  admin_regional
  admin_pusat
  admin_finance
  coordinator
  crew
}

enum ClaimStatus {
  pending
  regional_approved
  pusat_approved
  approved
  rejected
}

enum PaymentStatus {
  paid
  unpaid
  expired
}

enum PaymentVerificationStatus {
  pending_payment
  pending_verification
  verified
  rejected
}

enum ProfileLevel {
  basic
  silver
  gold
  platinum
}

enum RegistrationType {
  klaim
  pesantren_baru
}

enum PricingCategory {
  registration
  renewal
  upgrade
}

enum LetterDirection {
  incoming
  outgoing
}

enum LetterScope {
  pusat
  regional
}

enum LetterStatus {
  draft
  registered
  finalized
  archived
  rejected
}

enum LetterDocumentType {
  surat_keputusan
  surat_tugas
  surat_undangan
  surat_edaran
  surat_keterangan
  surat_rekomendasi
  berita_acara
  lainnya
}
